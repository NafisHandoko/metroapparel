# Metro Apparel Production Environment Variables
# Copy this file to .env.production and fill in the values

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# Medusa secrets (generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here
COOKIE_SECRET=your_cookie_secret_here

# Publishable Key (get from Medusa admin panel after first deployment)
# Settings > API Key Management > Publishable API Keys
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_xxxxx
