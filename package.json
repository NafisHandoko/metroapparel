{
  "name": "metroapparel",
  "private": false,
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "turbo test",
    "backend:seed": "turbo seed --filter=@metroapparel/backend",
    "backend:dev": "turbo dev --filter=@metroapparel/backend",
    "storefront:dev": "turbo dev --filter=@metroapparel/storefront",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:dev:up": "docker compose -f docker/development/docker-compose.yml up --build -d",
    "docker:dev:down": "docker compose -f docker/development/docker-compose.yml down",
    "docker:dev:logs": "docker compose -f docker/development/docker-compose.yml logs -f"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.5",
      "@types/react-dom": "19.0.5"
    }
  },
  "devDependencies": {
    "turbo": "^2.0.14",
    "prettier": "^3.2.5"
  }
}
