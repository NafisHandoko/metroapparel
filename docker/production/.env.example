# Salin ke `docker/production/.env` dan isi nilai sebelum `pnpm docker:prod:up`.
# Jangan commit `.env` (sudah di .gitignore).

# --- Postgres (wajib kuat di production) ---
POSTGRES_DB=medusa-store
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ganti-dengan-password-panjang-acak

# --- Medusa HTTP (wajib unik & rahasia) ---
JWT_SECRET=ganti-dengan-string-acak-panjang
COOKIE_SECRET=ganti-dengan-string-acak-panjang-lain

# CORS: sesuaikan domain toko & admin (HTTPS).
STORE_CORS=https://metroapparel.nafishandoko.my.id
ADMIN_CORS=https://admin.metroapparel.nafishandoko.my.id
AUTH_CORS=https://admin.metroapparel.nafishandoko.my.id,https://metroapparel.nafishandoko.my.id

# --- Storefront (publik) ---
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_...
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://admin.metroapparel.nafishandoko.my.id
NEXT_PUBLIC_BASE_URL=https://metroapparel.nafishandoko.my.id
NEXT_PUBLIC_DEFAULT_REGION=id

# SSR antar-container (jangan diubah jika pakai compose bawaan)
MEDUSA_BACKEND_INTERNAL_URL=http://medusa:9000

# Opsional: S3 Medusa Cloud
# MEDUSA_CLOUD_S3_HOSTNAME=
# MEDUSA_CLOUD_S3_PATHNAME=
